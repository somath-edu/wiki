---
import CornellNote from '../../../components/CornellNote.astro';

// 수식 변수
const mathOuterLimit = "$ \\displaystyle \\lim_{x \\to 1^+} g(f(x)) $";
const mathInnerLimit = "$ f(x) \\to 2^- $";
const mathFinalEq = "$ g(f(1)) $";

const mathFX = "$f(x)$";
const mathGT = "$g(t)$";
const mathX1 = "$x=1$";
const mathT2L = "$t \\to 2^-$";
---

<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>유형 04. 합성함수의 연속성 - 상세 연습</title>
		<!-- KaTeX -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
		<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
		<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js"></script>
		<style>
			body {
				background-color: #e0e0e0;
				margin: 0;
				padding: 20px;
				display: flex;
				justify-content: center;
			}
			/* [표준 디자인 시스템] 수직 계층 마스터피스 레이아웃 */
			.formula-box {
				text-align: center;
				margin: 35px 0;
				background: #fff;
				padding: 45px 30px;
				border-radius: 20px;
				border: 1px solid #eee;
				box-shadow: 0 4px 20px rgba(0,0,0,0.04);
				overflow: hidden;
				width: 100%;
				box-sizing: border-box;
			}
			.problem-premise {
				color: #555;
				font-size: 1.05rem;
				line-height: 1.8;
				margin-bottom: 35px;
				padding: 20px;
				background: #fcfcfc;
				border-radius: 12px;
				border: 1px dashed #ddd;
				word-break: keep-all;
			}
			.main-target {
				margin: 30px 0;
				padding: 25px 0;
				border-top: 1px solid #f0f0f0;
				border-bottom: 1px solid #f0f0f0;
			}
			.target-shout {
				display: block;
				font-weight: bold;
				color: #1a1a1a;
				font-size: 1.2rem;
				margin-top: 20px;
			}
			@media screen and (max-width: 480px) {
				.formula-box { padding: 35px 15px !important; }
				.problem-premise { font-size: 0.95rem !important; padding: 15px !important; }
				.katex-display { font-size: 0.9em !important; }
				body { padding: 10px; }
			}
		</style>
	</head>
	<body>
		<CornellNote title="유형 04. 합성함수의 연속성" chapter="Chapter 01 Practice">
			
			<div slot="cues">
				<p style="margin: 0; font-weight: bold; color: #1a1a1a;">🚀 해결 전략 체크리스트</p>
				<ul style="margin-top: 10px; padding-left: 18px; font-size: 11pt; line-height: 1.6; color: #444;">
					<li>안쪽 함수 $f(x)$의 극한 방향 확인</li>
					<li>바깥 함수 $g(t)$의 해당 지점 연속성</li>
					<li>치환 변수 $t$의 상태 변화 추적</li>
				</ul>
			</div>

			<section>
				<div class="type-section">
					<h4 style="margin-top: 0; color: #1a1a1a; border-bottom: 2px solid royalblue; display: inline-block; padding-bottom: 5px; margin-bottom: 25px;">
						[핵심 문제]
					</h4>
					
					<div class="formula-box">
						<!-- 1단계: 문제 조건 (The Context) -->
						<div class="problem-premise">
							함수 <span set:html={mathFX}></span>가 <span set:html={mathX1}></span>에서의 우극한이 $2$인 상태에서 아래쪽에서 접근하고, <br/>
							함수 <span set:html={mathGT}></span>가 <span set:html={mathT2L}></span>일 때 극한값이 $y$라고 할 때,
						</div>

						<!-- 2단계: 핵심 수식 (The Hero) -->
						<div class="main-target">
							<span set:html={"$$ \\lim_{x \\to 1^+} g(f(x)) $$"}></span>
							<span class="target-shout">의 값을 구하시오.</span>
						</div>
					</div>
					
					<!-- Strategy -->
					<details style="margin-top: 35px; border: 1px solid #eee; border-radius: 12px; padding: 15px; background: #fff;">
						<summary style="font-weight: bold; color: #1a73e8; cursor: pointer; padding: 5px;">💡 해결 전략</summary>
						<div style="margin-top: 10px; padding: 10px; border-top: 1px dashed #eee; color: #444; line-height: 1.6;">
							합성함수의 극한은 **'상태의 전이'**입니다. <span set:html={mathInnerLimit}></span>라는 사실이 바깥 함수 $g$의 '좌극한'을 보라는 명령이 됩니다.
						</div>
					</details>

					<!-- Solution -->
					<details style="margin-top: 15px; border: 1px solid #eee; border-radius: 12px; padding: 15px; background: #fff;">
						<summary style="font-weight: bold; color: #e63946; cursor: pointer; padding: 5px;">📝 단계별 풀이</summary>
						<div style="margin-top: 10px; padding: 10px; border-top: 1px dashed #eee; color: #444; line-height: 1.8;">
							<p><b>Step 1. 안쪽 극한 분석</b><br/>
							$x \to 1^+$일 때 $f(x)$가 아래쪽에서 $2$로 접근하므로 $f(x) \to 2^-$ 입니다.</p>
							<p><b>Step 2. 최종 극한 계산</b><br/>
							$t = f(x)$라 하면 $t \to 2^-$ 이므로, 바깥 함수 $g(t)$의 $2$에서의 **좌극한**을 찾습니다.</p>
						</div>
					</details>
				</div>

				<a href="/wiki/chapter01/problems-cont/" class="back-link" style="margin-top: 50px; display: inline-block;">← 유형별 목록으로 돌아가기</a>
			</section>
		</CornellNote>

		<script is:inline>
			if (typeof window !== 'undefined') {
				document.addEventListener("DOMContentLoaded", function() {
					if (typeof renderMathInElement === 'function') {
						renderMathInElement(document.body, {
							delimiters: [
								{left: '$$', right: '$$', display: true},
								{left: '$', right: '$', display: false}
							],
							throwOnError : false
						});
					}
				});
			}
		</script>
	</body>
</html>
