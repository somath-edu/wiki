---
import CornellNote from '../../../components/CornellNote.astro';

// 수식 변수 격리 (Astro 린트 에러 방지)
const mathMain = "$ f(x) = \\begin{cases} x^2+1 & (x \\ge 1) \\\\ x+a & (x < 1) \\end{cases} $";
const mathStep1 = "$ f(1) = 1^2+1 = 2 $";
const mathStep2 = "$ \\displaystyle \\lim_{x \\to 1^-} f(x) = 1+a $";
const mathStep3 = "$ 2 = 1+a \\implies a=1 $";

// 지문용 안전 변수
const txtX1 = "$x=1$";
const txtXge1 = "$x \\ge 1$";
const txtXlt1 = "$x < 1$";
---

<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>유형 10. 연속의 정의 - 상세 연습</title>
		<!-- KaTeX -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
		<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
		<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js"></script>
		<style>
			body {
				background-color: #e0e0e0;
				margin: 0;
				padding: 20px;
				display: flex;
				justify-content: center;
			}
			/* [표준 디자인 시스템] KaTeX & 모바일 수식 최적화 */
			.formula-box {
				text-align: center;
				margin: 30px 0;
				background: #fff;
				padding: 30px;
				border-radius: 12px;
				border: 1px solid #eee;
				box-shadow: 0 2px 8px rgba(0,0,0,0.02);
				overflow: hidden;
				width: 100%;
				box-sizing: border-box;
			}
			.math-container {
				width: 100%;
				overflow-x: auto;
				white-space: nowrap;
				-webkit-overflow-scrolling: touch;
				padding-bottom: 10px;
				display: flex;
				justify-content: center;
			}
			.katex-display {
				margin: 0.5em 0 !important;
				overflow-x: auto;
				overflow-y: hidden;
			}

			/* [표준 디자인 시스템] 난이도 내비게이션 최적화 */
			.difficulty-container {
				margin-top: 50px;
				padding: 25px;
				background: #f9f9f9;
				border-radius: 16px;
				border: 1px solid #eee;
			}
			.difficulty-list {
				display: flex;
				gap: 12px;
			}
			.difficulty-btn {
				flex: 1;
				padding: 15px;
				text-align: center;
				border-radius: 12px;
				text-decoration: none;
				font-weight: bold;
				font-size: 1.3rem;
				transition: transform 0.2s ease;
			}
			.difficulty-btn:active { transform: scale(0.95); }
			
			.btn-low { background: #eef7ee; color: #2e7d32; border: 1.5px solid #2e7d32; }
			.btn-mid { background: #ebf3ff; color: #1565c0; border: 1.5px solid #1565c0; }
			.btn-high { background: #fff8e1; color: #a0522d; border: 1.5px solid #a0522d; }

			@media screen and (max-width: 480px) {
				.formula-box { padding: 15px 5px !important; margin: 20px 0 !important; }
				.katex-display { font-size: 0.85em !important; }
				.formula-box p { font-size: 1rem !important; line-height: 1.5; }
				
				.difficulty-container { padding: 15px !important; }
				.difficulty-list { gap: 8px !important; }
				.difficulty-btn { 
					padding: 12px 5px !important; 
					font-size: 1.1rem !important; 
				}
				body { padding: 10px; }
			}
		</style>
	</head>
	<body>
		<CornellNote title="유형 10. 연속의 정의" chapter="Chapter 01 Practice">
			
			<div slot="cues">
				<p style="margin: 0; font-weight: bold; color: #1a1a1a;">💡 집중 공략 포인트</p>
				<ul style="margin-top: 10px; padding-left: 18px; font-size: 11pt; line-height: 1.6; color: #444;">
					<li>경계점에서 함숫값과 극한값이 일치하는가?</li>
					<li>좌극한과 우극한이 모두 같은 곳을 향하는가?</li>
				</ul>
			</div>

			<section>
				<div class="type-section">
					<h4 style="margin-top: 0; color: #1a1a1a; border-bottom: 2px solid royalblue; display: inline-block; padding-bottom: 5px; margin-bottom: 15px;">
						[핵심 문제]
					</h4>
					<p>다음 함수가 <span set:html={txtX1}></span>에서 연속이 되도록 하는 $a$의 값을 구하시오.</p>

					<div class="formula-box">
						<div class="math-container">
							<span set:html={mathMain}></span>
						</div>
						<p style="margin-top: 10px; color: #333; word-break: keep-all;">일 때, $a$의 값은?</p>
					</div>

					<!-- Step-by-Step Solution -->
					<details style="margin-top: 30px; border: 1px solid #eee; border-radius: 8px; padding: 10px; background: #fff;">
						<summary style="font-weight: bold; color: #e63946; cursor: pointer; padding: 5px;">📝 단계별 풀이 확인</summary>
						<div style="margin-top: 10px; padding: 10px; border-top: 1px dashed #eee; color: #444; line-height: 1.8;">
							<p><b>Step 1. 우극한 및 함숫값</b><br/>
							<span set:html={txtXge1}></span>인 식에 대입합니다.<br/>
							<span set:html={mathStep1}></span></p>
							
							<p><b>Step 2. 좌극한 확인</b><br/>
							<span set:html={txtXlt1}></span>인 식의 극한을 구합니다.<br/>
							<span set:html={mathStep2}></span></p>
							
							<p><b>Step 3. 최종 계산</b><br/>
							두 값이 같아야 하므로:<br/>
							<span set:html={mathStep3}></span></p>
						</div>
					</details>

					<!-- Difficulty Level Navigation -->
					<div class="difficulty-container">
						<p style="margin: 0 0 15px 0; font-weight: bold; color: #333; font-size: 1rem; display: flex; align-items: center; gap: 8px;">
							🎯 내 실력에 맞는 문제 도전하기
						</p>
						<div class="difficulty-list">
							<a href="/wiki/chapter01/levels/type10-low/" class="difficulty-btn btn-low">[하]</a>
							<a href="/wiki/chapter01/levels/type10-mid/" class="difficulty-btn btn-mid">[중]</a>
							<a href="/wiki/chapter01/levels/type10-high/" class="difficulty-btn btn-high">[상]</a>
						</div>
					</div>
				</div>

				<a href="/wiki/chapter01/problems-piecewise/" class="back-link" style="margin-top: 40px; display: inline-block;">← 유형별 목록으로 돌아가기</a>
			</section>
		</CornellNote>

		<script is:inline>
			if (typeof window !== 'undefined') {
				document.addEventListener("DOMContentLoaded", function() {
					if (typeof renderMathInElement === 'function') {
						renderMathInElement(document.body, {
							delimiters: [
								{left: '$$', right: '$$', display: true},
								{left: '$', right: '$', display: false}
							],
							throwOnError : false
						});
					}
				});
			}
		</script>
	</body>
</html>
