---
import CornellNote from '../../../components/CornellNote.astro';

// LaTeX constants
const limInf = "$\\displaystyle \\lim_{x \\to \\infty}$";
---

<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>유형 01 - 난이도 [하] 연습</title>
		<!-- KaTeX -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
		<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
		<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js"></script>
		<style>
			body {
				background-color: #e0e0e0;
				margin: 0;
				padding: 20px;
				display: flex;
				justify-content: center;
			}
		</style>
	</head>
	<body>
		<CornellNote title="유형 01. [하] 기초 탄탄" chapter="Level: Low">
			<div slot="cues">
				<p style="margin: 0; font-weight: bold; color: #1a1a1a;">🟢 기초 포인트</p>
				<ul style="margin-top: 10px; padding-left: 18px; font-size: 11pt; line-height: 1.6; color: #444;">
					<li>단순 계수 비교 집중</li>
					<li>빠른 풀이 속도 연습</li>
				</ul>
			</div>

			<section>
				<div class="type-section">
					<p style="margin-bottom: 20px;">기초적인 계수 비교를 통해 빠르게 정답을 찾는 연습을 합니다.</p>
					
					<div style="background: white; padding: 20px; border-radius: 12px; border: 1px solid #eee; margin-bottom: 20px;">
						<p><b>Q1.</b> 다음 극한값을 구하시오.</p>
						<p style="text-align: center; font-size: 1.4rem;">{limInf} { "$ \\frac{5x^2 + 1}{2x^2 - 3} $" }</p>
					</div>

					<div style="background: white; padding: 20px; border-radius: 12px; border: 1px solid #eee; margin-bottom: 20px;">
						<p><b>Q2.</b> 다음 극한값을 구하시오.</p>
						<p style="text-align: center; font-size: 1.4rem;">{limInf} { "$ \\frac{10x - 3}{5x + 7} $" }</p>
					</div>

					<div style="background: white; padding: 20px; border-radius: 12px; border: 1px solid #eee;">
						<p><b>Q3.</b> 다음 극한값을 구하시오.</p>
						<p style="text-align: center; font-size: 1.4rem;">{limInf} { "$ \\frac{4x^2 + 7x}{x^2 + 5} $" }</p>
					</div>
				</div>

				<div style="margin-top: 40px; display: flex; gap: 15px;">
					<a href="/wiki/chapter01/types/type01/" style="color: #666; text-decoration: none;">← 핵심 문제로 이동</a>
					<a href="/wiki/chapter01/problems-inf/" style="color: #666; text-decoration: none;">목록으로 돌아가기</a>
				</div>
			</section>
		</CornellNote>

		<script is:inline>
			if (typeof window !== 'undefined') {
				document.addEventListener("DOMContentLoaded", function() {
					if (typeof renderMathInElement === 'function') {
						renderMathInElement(document.body, {
							delimiters: [
								{left: '$$', right: '$$', display: true},
								{left: '$', right: '$', display: false}
							],
							throwOnError : false
						});
					}
				});
			}
		</script>
	</body>
</html>
