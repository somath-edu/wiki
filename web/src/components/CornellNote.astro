---
interface Props {
	title: string;
	chapter?: string;
}

const { title, chapter } = Astro.props;
import '../styles/cornell.css';
---

<div class="paper">
	<header class="cornell-header">
			<div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 10px;">
				<div style="flex: 1;">
					{chapter && <p style="font-family: var(--header-font); font-size: 10pt; margin: 0; color: #888;">{chapter}</p>}
					<h1 style="word-break: keep-all;">{title}</h1>
				</div>
				{!title.includes("목차") && 
					<a href="/wiki/" class="problem-link" style="margin-left: 0; background-color: rgba(0,0,0,0.05); color: #555; border-color: #ddd; flex-shrink: 0; white-space: nowrap;">📋 전체 목차</a>
				}
			</div>
	</header>

	<main class="cornell-main">
		<aside class="cornell-cues">
			<slot name="cues" />
		</aside>
		
		<article class="cornell-notes">
			<slot />
		</article>
	</main>

	<footer class="cornell-summary">
		<h3>Summary / 핵심 요조약</h3>
		<slot name="summary" />
	</footer>
</div>
