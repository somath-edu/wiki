---
interface Props {
	title: string;
	chapter?: string;
}

const { title, chapter } = Astro.props;
import '../styles/cornell.css';
---

<div class="paper">
	<header class="cornell-header">
			<div class="cornell-header-flex">
				<div class="cornell-header-title">
					{chapter && <p class="chapter-label">{chapter}</p>}
					<h1 style="word-break: keep-all;">{title}</h1>
				</div>
				{!title.includes("목차") && 
					<a href="/wiki/" class="problem-link mobile-nav-btn">📋 전체 목차</a>
				}
			</div>
	</header>

	<main class="cornell-main">
		<aside class="cornell-cues">
			<slot name="cues" />
		</aside>
		
		<article class="cornell-notes">
			<slot />
		</article>
	</main>

	<footer class="cornell-summary">
		<h3>Summary / 핵심 요조약</h3>
		<slot name="summary" />
	</footer>
</div>
